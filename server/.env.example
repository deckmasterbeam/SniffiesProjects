# Bearer token the extension must send in the Authorization header.
# Generate a long random string and paste it here AND into the extension popup.
SHARED_SECRET=

# TextBelt API key. Buy credits at https://textbelt.com.
# Use "textbelt" (no quotes) for the one free text per day during testing.
TEXTBELT_KEY=

# Optional comma-separated list of allowed Origin headers for CORS preflight.
# Chrome extensions send Origin: chrome-extension://<id>. Add yours here once
# the extension is loaded so you can lock the API down to just it.
# Leave blank to accept any origin (fine while developing).
ALLOWED_ORIGINS=
