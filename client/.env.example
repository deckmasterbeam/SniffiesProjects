# Base URL of the deployed server (no trailing slash).
SERVER_BASE=https://sniffies-projects.vercel.app

# Bearer token for client-facing API endpoints. Baked into the extension
# bundle, so it isn't truly secret — it just prevents casual scraping.
CLIENT_SECRET=ed6fd0cd-fe58-4dcc-83cd-65651771e0e9

# Set to true to enable debug overlays on sniffies.com.
DEBUG=false

# Set to true to enable the notification features (requires server support).
NOTIFICATIONS_ENABLED=false
