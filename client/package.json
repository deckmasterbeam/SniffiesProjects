{
  "name": "sniffies-plugins",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension exploring Sniffies plug-in ideas.",
  "scripts": {
    "build": "node --env-file=.env scripts/build.mjs",
    "build:prod": "node scripts/build-prod.mjs",
    "watch": "node --env-file=.env scripts/build.mjs --watch",
    "icons": "node scripts/generate-icons.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "lint-staged": {
    "*.{ts,html,css,mjs,json}": "prettier --write"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "esbuild": "^0.24.0",
    "jsdom": "^26.0.0",
    "lint-staged": "13",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
