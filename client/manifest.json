{
  "manifest_version": 3,
  "name": "Sniffies Projects - Chrome",
  "version": "0.1.0",
  "description": "A Chrome extension that enhances the Sniffies experience with additional features and SMS notifications.",
  "permissions": ["storage", "activeTab", "scripting", "geolocation"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Sniffies Projects - Chrome",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://sniffies.com/*", "*://*.sniffies.com/*"],
      "js": ["src/content/sniffies-geo-hook.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["*://sniffies.com/*", "*://*.sniffies.com/*"],
      "js": ["src/content/sniffies-geo-relay.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://sniffies.com/*", "*://*.sniffies.com/*"],
      "js": ["src/content/sniffies-profile-id.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["src/content/content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
