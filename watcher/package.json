{
  "name": "sniffies-watcher",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension that watches Sniffies WebSocket events and sends SMS notifications.",
  "scripts": {
    "build": "node --env-file=.env scripts/build.mjs",
    "watch": "node --env-file=.env scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "icons": "node scripts/generate-icons.mjs",
    "vm": "npm run build && docker compose -f docker/docker-compose.yml up --build",
    "vm:detach": "npm run build && docker compose -f docker/docker-compose.yml up --build -d",
    "vm:stop": "docker compose -f docker/docker-compose.yml down",
    "vm:reset-profile": "docker compose -f docker/docker-compose.yml down -v"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "esbuild": "^0.24.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3"
  }
}
